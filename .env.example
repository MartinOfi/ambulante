# Runtime environment (validados por shared/config/env.schema.ts con Zod)
# Copiar a .env.local y completar.

# Entorno de Node. Valores permitidos: development | test | production.
NODE_ENV=development

# URL pública base de la app (usada en metadata, links absolutos, callbacks).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry — obtener en sentry.io > Settings > Projects > Client Keys.
# NEXT_PUBLIC_SENTRY_DSN se embebe en el bundle del cliente (expuesto al browser).
# SENTRY_DSN es solo servidor; si está presente, tiene precedencia sobre el público.
# SENTRY_AUTH_TOKEN es necesario para subir source maps en CI/CD.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_AUTH_TOKEN=

# Mapa — estilo base para MapLibre GL JS (react-map-gl v8).
# Valor por defecto: demotiles de MapLibre (vector, sin API key).
# Para producción, considerar un tile server propio o Protomaps.
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# Upstash Redis — rate limiting distribuido para producción (reemplaza InMemoryRateLimiter).
# Crear en console.upstash.com > New Database > REST API.
# En desarrollo, se usa el limiter en memoria y estas vars son opcionales.
# UPSTASH_REDIS_REST_URL=https://<db>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dev local: pnpm supabase:start imprime estos valores al iniciar.
# Cloud: Settings > API en el dashboard de Supabase.

# URL pública del proyecto Supabase (cliente y servidor).
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Anon key — safe en el browser, respaldada por RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7w9Ic0HSz-AduJKTh9ifvfABQnJBNz-7Nos

# Service role key — bypasses RLS. NUNCA NEXT_PUBLIC_. Solo en server actions / route handlers.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0

# Pooler (PgBouncer) — transaction mode, puerto 6543.
# USAR SOLO en funciones serverless de Next.js (no en migraciones).
DATABASE_URL_POOLER=postgresql://postgres:postgres@localhost:54322/postgres

# Directo — puerto 5432. SOLO para migraciones con Supabase CLI / Prisma.
# Nunca en funciones serverless: las prepared statements rompen el pooler.
DATABASE_URL_DIRECT=postgresql://postgres:postgres@localhost:5432/postgres

# ── Cron jobs ─────────────────────────────────────────────────────────────────
# Secreto compartido entre pg_cron y los Route Handlers /api/cron/*.
# Mínimo 16 caracteres. Generar con: openssl rand -hex 32
# CRON_SECRET=

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY se usa en el browser para pushManager.subscribe().
# VAPID_PUBLIC_KEY + VAPID_PRIVATE_KEY se usan en el servidor para firmar notificaciones.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:push@ambulante.app

# --- Tooling local (no son runtime, no los lee shared/config/env.mjs) ---
# STITCH_API_KEY=
