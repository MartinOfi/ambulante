{
  "root": true,
  "extends": ["next/core-web-vitals", "plugin:@typescript-eslint/recommended", "prettier"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint", "local-rules"],
  "rules": {
    "local-rules/no-hardcoded-jsx-strings": "warn",
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/consistent-type-imports": [
      "error",
      { "prefer": "type-imports", "fixStyle": "inline-type-imports" }
    ],
    "@typescript-eslint/no-unused-vars": [
      "error",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
    ],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["../*", "../../*", "../../../*"],
            "message": "Use absolute imports with the @/ alias instead of parent-relative paths."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["features/landing/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@/features/map", "@/features/map/**"],
                "message": "Cross-feature imports are forbidden. Promote shared code to shared/."
              },
              {
                "group": ["../*", "../../*", "../../../*"],
                "message": "Use absolute imports with the @/ alias instead of parent-relative paths."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["features/map/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@/features/landing", "@/features/landing/**"],
                "message": "Cross-feature imports are forbidden. Promote shared code to shared/."
              },
              {
                "group": ["../*", "../../*", "../../../*"],
                "message": "Use absolute imports with the @/ alias instead of parent-relative paths."
              }
            ]
          }
        ]
      }
    }
  ],
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "out/",
    "build/",
    "dist/",
    "coverage/",
    "next-env.d.ts",
    "*.config.js",
    "*.config.mjs",
    "*.config.cjs",
    "*.config.ts"
  ]
}
